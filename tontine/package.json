{
  "name": "tontine",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "cross-env BUILD_ENV=true next build",
    "build:tontine": "npm --prefix .. run build:tontine",
    "build:stats": "cross-env ANALYZE=true npm run build",
    "dev": "next dev -p 3000",
    "format-lint": "npm --prefix .. run format-lint",
    "format-lint:fix": "npm --prefix .. run format-lint:fix",
    "generate-assets": "npm --prefix .. run generate-assets",
    "postbuild": "npm --prefix .. run postbuild",
    "run-tests": "npm --prefix .. run run-tests",
    "start": "next start -p 3000",
    "tc-report:tontine": "npm --prefix .. run tc-report:tontine",
    "tc-report": "type-coverage --project tsconfig.json",
    "typecheck": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "@mux/mux-video-react": "^0.30.5",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/client": "7.20.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.0",
    "@sentry/nextjs": "^10.46.0",
    "@tailwindcss/postcss": "^4.2.2",
    "axios": "1.14.0",
    "axios-retry": "^4.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "mixpanel-browser": "^2.77.0",
    "next": "16.2.1",
    "next-i18n-router": "^5.5.6",
    "next-sanity": "12.2.1",
    "next-share": "0.27.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-turnstile": "^1.1.5",
    "rss": "^1.2.2",
    "tailwind-merge": "^3.5.0",
    "@netlify/functions": "^5.1.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/rss": "^0.0.32",
    "cssnano": "7.1.3",
    "postcss": "^8.5.8",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4.2.2",
    "@biomejs/biome": "^2.4.10",
    "@types/node": "24.12.0",
    "cross-env": "10.1.0",
    "type-coverage": "^2.29.7",
    "typescript": "5.9.3"
  },
  "typeCoverage": {
    "ignoreFiles": [
      "coverage-ts/**/*",
      "**/*.json",
      "**/public/**/*",
      "**/.next/**/*",
      "**/out/**",
      "**/**.js",
      "**/**.jsx",
      "**/*.config.ts",
      "**/*.config.js"
    ],
    "strict": true,
    "atLeast": 9,
    "fileCounts": true
  }
}