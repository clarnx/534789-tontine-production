{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.mjs",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "**/next.config.ts",
    ".next/types/**/*.ts"
  ]
}
